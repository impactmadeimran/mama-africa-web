# Base URL for browser API calls.
# Dev: use /api (proxied to the backend by Vite — see VITE_API_PROXY_TARGET).
# Production: set to your deployed API origin, e.g. https://api.example.com
VITE_API_URL=/api

# Backend URL used by the Vite dev proxy (API server default port)
VITE_API_PROXY_TARGET=http://localhost:3001
